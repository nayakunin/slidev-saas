# Copy to .env.local and fill in the secret values before running `pnpm dev`

# S3 / MinIO (pre-filled for local dev with docker compose)
EXPORTER_BUCKET_ENDPOINT=http://localhost:9000
EXPORTER_BUCKET_FORCE_PATH_STYLE=true
EXPORTER_BUCKET_NAME=exports-local
EXPORTER_BUCKET_REGION=us-east-1
EXPORTER_BUCKET_ACCESS_KEY_ID=test
EXPORTER_BUCKET_SECRET_ACCESS_KEY=testtest123

# Server
HOST=0.0.0.0
PORT=3001
EXPORTER_MAX_CONCURRENT_JOBS=1

# Secrets — fill these in .env.local (never commit that file)
EXPORTER_SHARED_SECRET=
CONVEX_CALLBACK_SHARED_SECRET=
