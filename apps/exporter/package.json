{
  "name": "@app/exporter",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --on-success \"node --env-file=.env.local dist/server.mjs\"",
    "dev:server": "tsdown --watch --on-success \"node dist/server.mjs\"",
    "start": "node dist/server.mjs",
    "check-types": "tsgo --noEmit",
    "lint": "oxlint src",
    "fmt": "oxfmt src",
    "fmt:check": "oxfmt --check src",
    "test": "vitest run"
  },
  "dependencies": {
    "@app/backend": "workspace:*",
    "@aws-sdk/client-s3": "^3.1028.0",
    "@hono/node-server": "^1.19.13",
    "@marp-team/marp-cli": "^4.2.3",
    "@t3-oss/env-core": "^0.13.10",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:^",
    "@types/node": "^22.10.2",
    "@typescript/native-preview": "7.0.0-dev.20260407.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.2",
    "vitest": "^3.0.5"
  }
}
