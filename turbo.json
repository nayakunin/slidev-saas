{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "@app/web#build": {
      "passThroughEnv": [
        "WORKOS_API_KEY",
        "WORKOS_CLIENT_ID",
        "WORKOS_COOKIE_PASSWORD",
        "WORKOS_REDIRECT_URI"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "fmt": {
      "cache": false
    },
    "fmt:check": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@app/exporter#dev": {
      "cache": false,
      "persistent": true,
      "with": ["@infra/dev-infra#dev"]
    },
    "@infra/dev-infra#dev": {
      "cache": false,
      "persistent": true
    }
  }
}
